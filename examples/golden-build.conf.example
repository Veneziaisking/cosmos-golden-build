# /etc/systemd/system/CosmosCloud.service.d/golden-build.conf
#
# Golden Build v1.2.3 systemd hardening drop-in for CosmosCloud.
# Place this file at the path above. Do not modify CosmosCloud.service directly.
#
# ReadWritePaths=/srv /mnt /opt/cosmos (v1.2.3):
#   /srv     — full application data volume; required for Marketplace apps that use
#              absolute bind-mount paths outside /srv/cosmos and /srv/cosmos-storage
#   /mnt     — optional external storage; required for media-stack apps (Plex, Jellyfin)
#   /opt/cosmos — Cosmos binaries; required for cosmos-launcher self-update
#
# After placing this file, run:
#   systemctl daemon-reload
#   systemctl restart CosmosCloud

[Service]
User=media
Group=media
SupplementaryGroups=docker
AmbientCapabilities=CAP_NET_BIND_SERVICE
CapabilityBoundingSet=CAP_NET_BIND_SERVICE
NoNewPrivileges=true
Environment=COSMOS_CONFIG_FOLDER=/srv/cosmos/config/
ProtectSystem=strict
ProtectHome=true
PrivateTmp=true
ReadWritePaths=/srv /mnt /opt/cosmos
ProtectKernelTunables=true
ProtectKernelModules=true
ProtectControlGroups=true
RestrictSUIDSGID=true
LockPersonality=true
RestrictRealtime=true
